---
const codeLines = [
  { num: 1, text: "use jelly_core::{Kernel, Config};", type: "keyword" },
  { num: 2, text: "use std::path::PathBuf;", type: "keyword" },
  { num: 3, text: "" },
  { num: 4, text: "#[tokio::main]", type: "attribute" },
  { num: 5, text: "async fn main() -> Result<(), Box<dyn std::error::Error>> {", type: "def" },
  { num: 6, text: "    // Cold start kernel in 90ms", type: "comment" },
  { num: 7, text: "    let config = Config::builder()", type: "call" },
  { num: 8, text: "        .quiet_mode(true)", type: "call" },
  { num: 9, text: "        .build();", type: "call" },
  { num: 10, text: "" },
  { num: 11, text: "    let kernel = Kernel::boot(config).await?;", type: "call" },
  { num: 12, text: "    kernel.watch_project(PathBuf::from(\".\")).await?;", type: "call" },
  { num: 13, text: "" },
  { num: 14, text: "    Ok(())", type: "keyword" },
  { num: 15, text: "}", type: "punct" },
];
---

<div class="w-full overflow-hidden rounded-xl border border-zinc-800 bg-[#0e0e10] shadow-2xl">
  <!-- Title Bar -->
  <div class="flex h-11 items-center justify-between border-b border-zinc-800/80 bg-[#0b0b0d] px-4">
    <div class="flex items-center gap-2">
      <!-- macOS window controls -->
      <div class="h-3 w-3 rounded-full bg-[#ff5f56]"></div>
      <div class="h-3 w-3 rounded-full bg-[#ffbd2e]"></div>
      <div class="h-3 w-3 rounded-full bg-[#27c93f]"></div>
    </div>
    <div class="font-mono text-[11.5px] tracking-tight text-zinc-400">
      main.rs — Jelly
    </div>
    <div class="w-14"></div> <!-- Spacer to balance window controls -->
  </div>

  <div class="flex min-h-[420px] text-zinc-300">
    <!-- Sidebar File Explorer -->
    <div class="hidden w-52 shrink-0 border-r border-zinc-800/80 bg-[#09090b] p-3 md:block">
      <div class="mb-4 font-mono text-[10px] uppercase tracking-wider text-zinc-500 font-bold">
        Project
      </div>
      <div class="space-y-1.5 font-mono text-[12px] text-zinc-400">
        <div class="flex items-center gap-2 text-zinc-500">
          <span>▼</span> 📁 <span>src</span>
        </div>
        <div class="flex items-center gap-2 pl-4 text-[#ff2e93] font-medium">
          <span>📄</span> <span>main.rs</span>
        </div>
        <div class="flex items-center gap-2 pl-4">
          <span>📄</span> <span>kernel.rs</span>
        </div>
        <div class="flex items-center gap-2 pl-4">
          <span>📄</span> <span>protocol.rs</span>
        </div>
        <div class="flex items-center gap-2">
          <span>▶</span> 📁 <span>packages</span>
        </div>
        <div class="flex items-center gap-2">
          <span>📄</span> <span>Cargo.toml</span>
        </div>
        <div class="flex items-center gap-2">
          <span>📄</span> <span>README.md</span>
        </div>
      </div>
    </div>

    <!-- Editor Area -->
    <div class="flex-1 bg-[#0c0c0e]">
      <!-- Tab Bar -->
      <div class="flex h-9 border-b border-zinc-800/60 bg-[#0a0a0c]">
        <div class="flex items-center gap-2 border-r border-zinc-800/80 bg-[#0c0c0e] px-4 font-mono text-[12px] text-[#ff2e93] font-medium">
          <span>main.rs</span>
          <span class="text-[10px] text-zinc-500 hover:text-zinc-300 cursor-pointer">×</span>
        </div>
        <div class="flex items-center gap-2 border-r border-zinc-800/40 px-4 font-mono text-[12px] text-zinc-500 hover:bg-zinc-900/30 cursor-pointer">
          <span>kernel.rs</span>
        </div>
      </div>

      <div class="overflow-x-auto p-4 font-mono text-[12.5px] leading-relaxed select-none">
        {codeLines.map((line) => {
          let styleClass = "text-zinc-400";
          if (line.type === "keyword") styleClass = "text-[#8b5cf6] font-medium"; // purple
          if (line.type === "attribute") styleClass = "text-[#ec4899]"; // pink
          if (line.type === "def") styleClass = "text-zinc-200 font-semibold";
          if (line.type === "decl") styleClass = "text-zinc-300";
          if (line.type === "comment") styleClass = "text-zinc-600 italic";
          if (line.type === "call") styleClass = "text-zinc-300";
          if (line.type === "value") styleClass = "text-[#e2b053]";
          if (line.type === "string") styleClass = "text-[#10b981]";

          return (
            <div class="flex hover:bg-zinc-900/20">
              <span class="w-9 shrink-0 pr-3 text-right font-mono text-[11px] text-zinc-600 select-none">
                {line.num}
              </span>
              <span class={`${styleClass} whitespace-pre`}>{line.text}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Status Bar -->
  <div class="flex h-6 items-center justify-between border-t border-zinc-800/80 bg-[#08080a] px-4 font-mono text-[10.5px] text-zinc-500">
    <div class="flex items-center gap-3">
      <span class="text-zinc-400">Normal</span>
      <span>·</span>
      <span>main</span>
    </div>
    <div class="flex items-center gap-3">
      <span>UTF-8</span>
      <span>·</span>
      <span>Rust</span>
      <span class="text-[#27c93f]">● Connected</span>
    </div>
  </div>
</div>
