---
import JellyShape from "@/components/jelly/JellyShape.astro";
import pkg from "../../../../../package.json";

const envVersion = process.env.PUBLIC_VERSION;
const rawVersion = (envVersion && envVersion !== 'main') ? envVersion : pkg.version;
const version = rawVersion.startsWith('v') ? rawVersion.slice(1) : rawVersion;
---

<section id="download" class="relative overflow-hidden">
  <div class="pointer-events-none absolute -left-16 bottom-0 hidden md:block">
    <JellyShape variant="pebble" class="h-32 w-32 text-jelly-cream" />
  </div>
  <div class="pointer-events-none absolute right-10 top-10 hidden md:block">
    <JellyShape variant="blob" class="h-20 w-20 text-jelly-soft/40" />
  </div>

  <div class="mx-auto max-w-[1240px] px-6 py-28 text-center md:py-36">
    <h2 class="mx-auto max-w-2xl text-balance text-[44px] font-semibold leading-[1.05] tracking-[-0.03em] text-ink md:text-[56px]">
      Less IDE. More control.
    </h2>
    <p class="mx-auto mt-5 max-w-lg text-[16px] text-ink-muted">
      Get a clean, fast workspace to inspect and guide your AI agent without the weight of a full IDE.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        id="cta-dl-mac"
        href="https://github.com/jelly-editor/jelly-editor/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        data-platform="mac"
        class="inline-flex h-11 cursor-pointer items-center gap-2 rounded-full bg-ink px-6 text-[14px] font-medium text-background transition-transform hover:-translate-y-px"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
          <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 135.4-317.3 269-317.3 71 0 130.3 46.4 175.1 46.4 42.8 0 109.6-49 192.9-49 31.3 0 108.2 2.6 168.1 71.9zm-136-99.4c32.7-39.5 56.1-94.4 56.1-149.3 0-7.8-.6-15.6-2-22.7-53.5 2-117.1 35.7-155.5 79.5-31.3 36.3-59.9 91.3-59.9 147.5 0 8.4 1.3 16.7 2 19.3 3.3.6 8.5 1.3 13.7 1.3 47.7 0 108.2-32 145.6-75.6z" />
        </svg>
        macOS
      </a>

      <a
        id="cta-dl-windows"
        href="https://github.com/jelly-editor/jelly-editor/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        data-platform="windows"
        class="inline-flex h-11 cursor-pointer items-center gap-2 rounded-full border border-rule bg-surface px-6 text-[14px] font-medium text-ink transition-colors hover:bg-surface-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
          <path d="M0 93.7l183.6-25.3v177.4H0V93.7zm0 324.6l183.6 25.3V268.4H0v149.9zm203.8 28L448 480V268.4H203.8v177.9zm0-380.6v178H448V32L203.8 65.7z" />
        </svg>
        Windows
      </a>

      <a
        id="cta-dl-linux"
        href="https://github.com/jelly-editor/jelly-editor/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        data-platform="linux"
        class="inline-flex h-11 cursor-pointer items-center gap-2 rounded-full border border-rule bg-surface px-6 text-[14px] font-medium text-ink transition-colors hover:bg-surface-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
          <polyline points="4 17 10 11 4 5" />
          <line x1="12" y1="19" x2="20" y2="19" />
        </svg>
        Linux
      </a>

      <a
        href="https://github.com/jelly-editor/jelly-editor/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-11 items-center gap-2 rounded-full border border-rule bg-surface px-6 text-[14px] font-medium text-ink transition-colors hover:bg-surface-2"
      >
        Changelog →
      </a>
    </div>

    <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-faint">
      v{version} · macOS 13+ · Windows 10+ · Ubuntu 20.04+ / Debian 11+
    </p>
  </div>
</section>

<script>
  const GITHUB_API = "https://api.github.com/repos/jelly-editor/jelly-editor/releases/latest";

  async function populateCTALinks() {
    try {
      const res = await fetch(GITHUB_API, {
        headers: { Accept: "application/vnd.github+json" },
      });
      if (!res.ok) return;
      const { assets = [] } = await res.json() as { assets: { name: string; browser_download_url: string }[] };

      const urls: Record<string, string | undefined> = {
        mac: assets.find((a) => a.name.endsWith(".dmg"))?.browser_download_url,
        windows: assets.find((a) => a.name.endsWith("-setup.exe"))?.browser_download_url,
        linux: assets.find((a) => a.name.endsWith(".deb"))?.browser_download_url,
      };

      document.querySelectorAll<HTMLAnchorElement>("[data-platform]").forEach((link) => {
        const platform = link.dataset.platform!;
        const url = urls[platform];
        if (url) link.href = url;
      });
    } catch {
      // keep fallback hrefs pointing to releases page
    }
  }

  document.querySelectorAll<HTMLAnchorElement>("[data-platform]").forEach((link) => {
    link.addEventListener("click", () => {
      (window as any).umami?.track("download", { os: link.dataset.platform });
    });
  });

  populateCTALinks();
</script>
