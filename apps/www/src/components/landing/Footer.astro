---
const cols = [
  {
    h: "Product",
    l: [
      { name: "Download", href: "https://github.com/jelly-editor/jelly-editor/releases/latest" },
      { name: "Changelog", href: "https://github.com/jelly-editor/jelly-editor/releases" },
      { name: "Roadmap", href: "#" },
      { name: "Pricing", href: "#" },
    ],
  },
  {
    h: "Resources",
    l: [
      { name: "Documentation", href: "#" },
      { name: "Keybindings", href: "#" },
      { name: "GitHub", href: "https://github.com/jelly-editor/jelly-editor" },
      { name: "Community", href: "#" },
    ],
  },
  {
    h: "Company",
    l: [
      { name: "About", href: "#" },
      { name: "Blog", href: "#" },
      { name: "Careers", href: "#" },
      { name: "Contact", href: "#" },
    ],
  },
];
---

<footer class="border-t border-rule/70 bg-surface">
  <div class="mx-auto max-w-[1240px] px-6 py-14">
    <div class="grid gap-10 md:grid-cols-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-2.5">
          <img src="/jelly.png" alt="Jelly Logo" class="h-6 w-6 object-contain" />
          <span class="text-[15px] font-semibold tracking-tight">Jelly</span>
        </div>
        <p class="mt-4 max-w-xs text-[13.5px] leading-relaxed text-ink-muted">
          A lightweight desktop editor for agentic coding. Designed and built in Lisbon &amp; Brooklyn.
        </p>
      </div>

      {cols.map((col) => (
        <div class="md:col-span-2">
          <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-faint">
            {col.h}
          </p>
          <ul class="space-y-2.5 text-[13.5px] text-ink-muted">
            {col.l.map((x) => (
              <li>
                <a href={x.href} class="transition-colors hover:text-ink">{x.name}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-between gap-3 border-t border-rule pt-6 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-faint">
      <span>© 2026 Jelly Software, Inc.</span>
      <span>Built natively. No tracking.</span>
    </div>
  </div>
</footer>
