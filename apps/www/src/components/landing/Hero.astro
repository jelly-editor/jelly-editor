---
import JellyShape from "@/components/jelly/JellyShape.astro";
import DownloadButton from "@/components/ui/DownloadButton.astro";
import pkg from "../../../../../package.json";

const envVersion = process.env.PUBLIC_VERSION;
// Use environment version if it looks like a version/tag (and isn't the branch name 'main'), otherwise package version
const rawVersion = (envVersion && envVersion !== 'main') ? envVersion : pkg.version;
const version = rawVersion.startsWith('v') ? rawVersion.slice(1) : rawVersion;
---

<section class="relative overflow-hidden">
  <!-- subtle decorative jelly shape — sparingly used, no gradients -->
  <div class="pointer-events-none absolute -right-24 top-32 hidden lg:block">
    <JellyShape variant="capsule" class="h-44 w-44 text-jelly-cream" />
  </div>
  <div class="pointer-events-none absolute -left-12 top-[420px] hidden lg:block">
    <JellyShape variant="pebble" class="h-24 w-24 text-jelly-soft/60" />
  </div>

  <div class="mx-auto max-w-[1240px] px-6 pt-20 pb-10 md:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-rule bg-surface px-3 py-1 text-[11.5px] text-ink-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-jelly-magenta"></span>
        <span class="font-mono uppercase tracking-[0.14em]">v{version} · Public beta</span>
      </div>

      <h1 class="text-balance text-[44px] font-semibold leading-[1.04] tracking-[-0.035em] text-ink md:text-[68px]">
        An editor for the<br />agentic coding era.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-pretty text-[16.5px] leading-[1.55] text-ink-muted md:text-[17.5px]">
        Jelly gives you a clean, fast workspace to inspect code, review changes, search projects, use git, and guide your AI agent without the weight of a full IDE.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <DownloadButton
          id="hero-download-btn"
          label="Download for macOS"
          autoOsLabel={true}
          class="inline-flex h-10 cursor-pointer items-center gap-2 rounded-full bg-ink px-5 text-[13.5px] font-medium text-background transition-transform hover:-translate-y-px disabled:cursor-wait"
        />
        <a
          href="https://github.com/jelly-editor/jelly-editor"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 items-center gap-2 rounded-full border border-rule bg-surface px-5 text-[13.5px] font-medium text-ink transition-colors hover:bg-surface-2"
        >
          View source code
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="mt-4 text-[13px] text-ink-faint">
        <a href="#download" class="underline underline-offset-2 hover:text-ink-muted transition-colors">
          Looking for another platform?
        </a>
      </p>
    </div>

    <!-- Product UI — theme-aware screenshot -->
    <div class="relative mt-16 md:mt-20">
      <picture id="hero-screenshot">
        <!-- Dark mode (system preference) -->
        <source
          srcset="/assets/screenshots/editor-dark.png"
          media="(prefers-color-scheme: dark)"
          data-theme="dark"
        />
        <!-- Light mode fallback -->
        <img
          src="/assets/screenshots/editor-light.png"
          alt="Jelly Editor User Interface showing a clean, lightweight workspace"
          class="w-full h-auto"
          width="1920"
          height="1080"
        />
      </picture>
    </div>
  </div>
</section>

<script>
  function updateScreenshot() {
    const root = document.documentElement;
    const isDark = root.classList.contains("dark") ||
      (!root.classList.contains("light") && window.matchMedia("(prefers-color-scheme: dark)").matches);

    const source = document.querySelector<HTMLSourceElement>("#hero-screenshot source");
    const img = document.querySelector<HTMLImageElement>("#hero-screenshot img");
    if (!source || !img) return;

    if (isDark) {
      source.media = "all"; // always match → browser picks source
      img.src = "/assets/screenshots/editor-dark.png";
    } else {
      source.media = "not all"; // never match → browser falls back to img
      img.src = "/assets/screenshots/editor-light.png";
    }
  }

  // Run on load
  updateScreenshot();

  // React to manual toggle (class change on <html>)
  new MutationObserver(updateScreenshot).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });
</script>
