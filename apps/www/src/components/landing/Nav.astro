---
---

<header class="sticky top-0 z-40 border-b border-rule/70 bg-background/85 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-[1240px] items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/jelly.png" alt="Jelly Logo" class="h-6 w-6 object-contain" />
      <span class="text-[15px] font-semibold tracking-tight">Jelly</span>
    </a>
    <nav class="hidden items-center gap-8 text-[13px] text-ink-muted md:flex">
      <a href="#features" class="transition-colors hover:text-ink">Features</a>
      <a href="#craft" class="transition-colors hover:text-ink">Craft</a>
      <a href="#specs" class="transition-colors hover:text-ink">Specs</a>
      <a href="#changelog" class="transition-colors hover:text-ink">Changelog</a>
      <a href="#docs" class="transition-colors hover:text-ink">Docs</a>
    </nav>
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/jelly-editor/jelly-editor"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:inline"
      >
        GitHub
      </a>
      <a
        href="https://github.com/jelly-editor/jelly-editor/releases/latest"
        class="inline-flex h-8 items-center gap-1.5 rounded-full bg-ink px-3.5 text-[12.5px] font-medium text-background transition-transform hover:-translate-y-px"
      >
        Download
        <span class="text-background/60">·</span>
        <span class="font-mono text-[11px] text-background/70">macOS</span>
      </a>
    </div>
  </div>
</header>
