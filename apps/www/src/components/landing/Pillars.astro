---
const items = [
  {
    kicker: "Review",
    title: "Built for agentic workflows.",
    body: "Jelly is built for a workflow where the AI agent writes most of the code through the terminal, and you review, navigate, and direct.",
  },
  {
    kicker: "Zero Bloat",
    title: "No duplicate overhead.",
    body: "Your CLI agent already runs tsc, eslint, and tests. Jelly stays quiet and lightweight, saving memory and CPU by not duplicating background services.",
  },
  {
    kicker: "Lightweight",
    title: "Designed to disappear.",
    body: "A native desktop editor that loads instantly (under 90ms) and recedes so you can inspect code and verify diffs without any IDE bloat.",
  },
];
---

<section id="features" class="border-b border-rule/70">
  <div class="mx-auto max-w-[1240px] px-6 py-24 md:py-32">
    <div class="grid gap-x-12 gap-y-10 md:grid-cols-3">
      {items.map((it, i) => (
        <div class="flex flex-col">
          <div class="mb-6 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ink-faint">
            <span>0{i + 1}</span>
            <span class="h-px w-8 bg-rule"></span>
            <span>{it.kicker}</span>
          </div>
          <h3 class="text-[24px] font-semibold leading-tight tracking-[-0.02em] text-ink">
            {it.title}
          </h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-muted">{it.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
