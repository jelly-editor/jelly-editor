---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: "Instant code review",
    body: "Jump to any file the agent touches. See diffs, follow changes, and stay oriented without losing your thread.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    title: "Terminal-first",
    body: "Your CLI agent drives the terminal. Jelly sits beside it — no duplicate runtimes, no background services fighting for resources.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
    title: "Inbuilt notes",
    body: "Capture ideas and decisions scoped to your working directory — saved locally, and exposed via MCP so your AI agent can read and update them too.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: "Extension architecture",
    body: "Every feature — files, editor, git, terminal — is an isolated extension. Swap, disable, or add your own without touching the core.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    title: "Zero config themes",
    body: "Adaptive light and dark modes that respect your OS preference, with a single toggle override. No JSON files, no theme editor.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
    title: "Built-in git",
    body: "Stage hunks, read history, and resolve conflicts from the sidebar — without leaving the editor or opening a separate Git GUI.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><path d="M8 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="17"/><line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/></svg>`,
    title: "Mini games",
    body: "Take a short break without breaking flow — a handful of lightweight games are built right in to help you recharge between deep work sessions.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Privacy by design",
    body: "All indexing runs locally. Your source code never leaves your machine — no telemetry, no cloud sync, no vendor lock-in.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "Multi-panel layouts",
    body: "Split the workspace any way you need — editor beside terminal, diff beside file tree. Layouts are saved and restored per project.",
  },
];
---

<section id="features" class="border-b border-rule/70">
  <div class="mx-auto max-w-[1240px] px-6 py-24 md:py-32">
    <div class="mb-16 max-w-xl">
      <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ink-faint">Features</p>
      <h2 class="text-[32px] font-semibold leading-tight tracking-[-0.02em] text-ink md:text-[36px]">
        Everything you need.<br />Nothing you don't.
      </h2>
    </div>

    <div class="grid gap-px bg-rule/70 border border-rule/70 rounded-xl overflow-hidden md:grid-cols-3">
      {features.map((f) => (
        <div class="group flex flex-col gap-4 bg-background p-7 transition-colors duration-150 hover:bg-surface">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-rule/70 bg-surface text-ink-muted transition-colors duration-150 group-hover:border-jelly-violet/30 group-hover:bg-jelly-soft group-hover:text-jelly-violet">
            <Fragment set:html={f.icon} />
          </div>
          <div>
            <h3 class="mb-1.5 text-[15px] font-semibold tracking-[-0.01em] text-ink">{f.title}</h3>
            <p class="text-[13.5px] leading-relaxed text-ink-muted">{f.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
