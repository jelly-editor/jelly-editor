---
import JellyShape from "@/components/jelly/JellyShape.astro";
---

<section class="border-b border-rule/70">
  <div class="mx-auto max-w-[900px] px-6 py-24 text-center md:py-32">
    <JellyShape variant="capsule" class="mx-auto mb-8 h-10 w-10 text-jelly-pink" />
    <p class="text-balance text-[28px] font-medium leading-[1.25] tracking-[-0.02em] text-ink md:text-[34px]">
      “Jelly feels like the editor was designed by someone who actually writes code for a
      living. It just gets out of the way.”
    </p>
    <div class="mt-8 flex items-center justify-center gap-3 text-[13px] text-ink-muted">
      <img
        src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=56&h=56&fit=crop&crop=face&auto=format&q=80"
        alt="Mira Chen"
        class="h-7 w-7 rounded-full object-cover"
        width="28"
        height="28"
      />
      <span class="font-medium text-ink">Mira Chen</span>
      <span class="text-ink-faint">·</span>
      <span>Staff Engineer, Inkwell</span>
    </div>
  </div>
</section>
