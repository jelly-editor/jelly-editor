---
/**
 * DownloadButton
 *
 * Fetches the latest .dmg release asset from the GitHub API and triggers a
 * direct file download. Falls back to the releases page if the API is
 * unavailable or no .dmg is found.
 *
 * Props
 * -----
 * class   — extra Tailwind classes forwarded to the <button> element
 * size    — "sm" | "md" (default "md")
 * label   — button text (default "Download for macOS")
 * showIcon — whether to render the Apple icon (default true)
 */

interface Props {
  class?: string;
  size?: "sm" | "md";
  label?: string;
  showIcon?: boolean;
  id?: string;
}

const {
  class: className = "",
  size = "md",
  label = "Download for macOS",
  showIcon = true,
  id = "download-btn",
} = Astro.props;
---

<button
  id={id}
  type="button"
  data-download-btn
  class={className}
  aria-label="Download Jelly for macOS"
>
  {showIcon && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 814 1000"
      fill="currentColor"
      class={size === "sm" ? "h-3.5 w-3.5" : "h-3.5 w-3.5"}
      aria-hidden="true"
    >
      <!-- Apple logo path -->
      <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 135.4-317.3 269-317.3 71 0 130.3 46.4 175.1 46.4 42.8 0 109.6-49 192.9-49 31.3 0 108.2 2.6 168.1 71.9zm-136-99.4c32.7-39.5 56.1-94.4 56.1-149.3 0-7.8-.6-15.6-2-22.7-53.5 2-117.1 35.7-155.5 79.5-31.3 36.3-59.9 91.3-59.9 147.5 0 8.4 1.3 16.7 2 19.3 3.3.6 8.5 1.3 13.7 1.3 47.7 0 108.2-32 145.6-75.6z" />
    </svg>
  )}
  <span data-label>{label}</span>
  <span data-spinner class="hidden">
    <svg
      class={size === "sm" ? "h-3.5 w-3.5 animate-spin" : "h-4 w-4 animate-spin"}
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </span>
</button>

<script>
  const GITHUB_API =
    "https://api.github.com/repos/jelly-editor/jelly-editor/releases/latest";
  const FALLBACK =
    "https://github.com/jelly-editor/jelly-editor/releases/latest";

  async function fetchLatestDmg(): Promise<string | null> {
    try {
      const res = await fetch(GITHUB_API, {
        headers: { Accept: "application/vnd.github+json" },
      });
      if (!res.ok) return null;
      const data = await res.json();
      const assets: { name: string; browser_download_url: string }[] =
        data.assets ?? [];
      const dmg = assets.find((a) => a.name.endsWith(".dmg"));
      return dmg?.browser_download_url ?? null;
    } catch {
      return null;
    }
  }

  function setLoading(btn: HTMLButtonElement, loading: boolean) {
    const label = btn.querySelector("[data-label]");
    const spinner = btn.querySelector("[data-spinner]");
    btn.disabled = loading;
    if (loading) {
      label?.classList.add("opacity-50");
      spinner?.classList.remove("hidden");
    } else {
      label?.classList.remove("opacity-50");
      spinner?.classList.add("hidden");
    }
  }

  async function handleDownload(btn: HTMLButtonElement) {
    setLoading(btn, true);
    const url = await fetchLatestDmg();
    setLoading(btn, false);

    if (url) {
      // Trigger browser download without navigation
      const a = document.createElement("a");
      a.href = url;
      a.download = "";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    } else {
      // Graceful fallback
      window.open(FALLBACK, "_blank", "noopener,noreferrer");
    }
  }

  document.querySelectorAll<HTMLButtonElement>("[data-download-btn]").forEach((btn) => {
    btn.addEventListener("click", () => handleDownload(btn));
  });
</script>
