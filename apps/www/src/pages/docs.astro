---
import "../styles/global.css";

const sections = [
  {
    group: "Getting Started",
    items: ["What is Jelly?", "Download & install", "Open a project", "Interface overview"],
  },
  {
    group: "Editor",
    items: ["Opening files", "Tabs & split view", "Search & replace", "Code folding", "Minimap"],
  },
  {
    group: "Terminal",
    items: ["Using the terminal", "Multiple sessions", "Shell profiles", "Keyboard shortcuts"],
  },
  {
    group: "Git",
    items: ["Viewing changes", "Staging & committing", "Push & pull", "Branches", "Commit history"],
  },
  {
    group: "Settings",
    items: ["Preferences", "Keybindings", "Themes", "Font & editor"],
  },
  {
    group: "Tips & Tricks",
    items: ["Command palette", "Keyboard shortcuts", "Working with AI agents"],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Docs — Jelly Editor</title>
    <meta name="description" content="Documentation for Jelly, the lightweight desktop editor for agentic coding." />
  </head>

  <body class="bg-background text-ink selection:bg-jelly-cream/80" style="overflow: hidden; height: 100dvh;">

    <!-- Docs shell -->
    <div class="flex h-dvh flex-col" style="height: 100dvh;">

      <!-- Top bar -->
      <header class="flex h-12 shrink-0 items-center justify-between border-b border-rule/70 bg-background/90 px-5 backdrop-blur-md">
        <div class="flex items-center gap-5">
          <a href="/" class="flex items-center gap-2 text-[13px] font-semibold tracking-tight text-ink">
            <img src="/jelly.png" alt="Jelly" class="h-5 w-5 object-contain" />
            Jelly
          </a>
          <span class="h-3.5 w-px bg-rule"></span>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">Docs</span>
        </div>

        <div class="flex items-center gap-4">
          <!-- Fake search -->
          <button
            type="button"
            class="hidden items-center gap-2 rounded-lg border border-rule/80 bg-surface px-3 py-1.5 text-[12px] text-ink-faint transition-colors hover:border-rule hover:bg-surface-2 sm:flex"
            aria-label="Search docs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
            <span>Search…</span>
            <kbd class="ml-2 rounded border border-rule/70 bg-surface-2 px-1 py-0.5 font-mono text-[10px] text-ink-faint">⌘K</kbd>
          </button>

          <a
            href="https://github.com/jelly-editor/jelly-editor"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[12.5px] text-ink-faint transition-colors hover:text-ink"
          >
            GitHub
          </a>
        </div>
      </header>

      <!-- Body: sidebar + content -->
      <div class="flex flex-1 overflow-hidden">

        <!-- Sidebar -->
        <aside class="hidden w-56 shrink-0 overflow-y-auto border-r border-rule/70 bg-surface py-6 md:block xl:w-64">
          <nav class="px-4">
            {sections.map((sec) => (
              <div class="mb-6">
                <p class="mb-2 px-2 font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">
                  {sec.group}
                </p>
                <ul class="space-y-0.5">
                  {sec.items.map((item, i) => (
                    <li>
                      <button
                        type="button"
                        class={`w-full rounded-md px-2 py-1.5 text-left text-[13px] transition-colors
                          ${sec.group === "Getting Started" && i === 0
                            ? "bg-surface-2 font-medium text-ink"
                            : "text-ink-muted hover:bg-surface-2 hover:text-ink"
                          }`}
                      >
                        {item}
                      </button>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <!-- Main content area — coming soon state -->
        <main class="relative flex flex-1 flex-col items-center justify-center overflow-y-auto p-8">

          <!-- Blurred ghost content backdrop -->
          <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
            <div class="mx-auto max-w-2xl px-8 pt-16 opacity-[0.06]">
              <div class="mb-3 h-4 w-24 rounded-full bg-ink"></div>
              <div class="mb-8 h-10 w-72 rounded-xl bg-ink"></div>
              <div class="mb-3 h-3 w-full rounded-full bg-ink"></div>
              <div class="mb-3 h-3 w-5/6 rounded-full bg-ink"></div>
              <div class="mb-3 h-3 w-4/5 rounded-full bg-ink"></div>
              <div class="mb-8 h-3 w-3/4 rounded-full bg-ink"></div>
              <div class="mb-6 h-28 w-full rounded-xl bg-ink"></div>
              <div class="mb-3 h-3 w-full rounded-full bg-ink"></div>
              <div class="mb-3 h-3 w-5/6 rounded-full bg-ink"></div>
              <div class="mb-3 h-3 w-2/3 rounded-full bg-ink"></div>
            </div>
          </div>

          <!-- Coming soon card -->
          <div class="relative z-10 mx-auto max-w-sm text-center">
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-rule bg-surface text-2xl shadow-sm">
              📖
            </div>
            <h1 class="mb-3 text-[26px] font-semibold tracking-[-0.02em] text-ink">
              Docs coming soon
            </h1>
            <p class="mb-7 text-[14px] leading-relaxed text-ink-muted">
              We're writing the documentation while we build. Check back once
              v0.2 ships — everything will be here.
            </p>
            <div class="flex items-center justify-center gap-3">
              <a
                href="/"
                class="inline-flex h-9 items-center rounded-full bg-ink px-4 text-[13px] font-medium text-background transition-transform hover:-translate-y-px"
              >
                Back home
              </a>
              <a
                href="https://github.com/jelly-editor/jelly-editor"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-9 items-center rounded-full border border-rule bg-surface px-4 text-[13px] font-medium text-ink transition-colors hover:bg-surface-2"
              >
                GitHub →
              </a>
            </div>
          </div>

        </main>
      </div>
    </div>

  </body>
</html>
