---
import Nav from "@/components/landing/Nav.astro";
import Hero from "@/components/landing/Hero.astro";
import Marquee from "@/components/landing/Marquee.astro";
import Pillars from "@/components/landing/Pillars.astro";
import FeatureSplit from "@/components/landing/FeatureSplit.astro";
import CommandSection from "@/components/landing/CommandSection.astro";
import SpecGrid from "@/components/landing/SpecGrid.astro";
import Quote from "@/components/landing/Quote.astro";
import CTA from "@/components/landing/CTA.astro";
import Footer from "@/components/landing/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jelly — Lightweight desktop editor for agentic AI coding</title>
    <meta name="description" content="Jelly is a lightweight desktop code editor built for developers who code with AI agents. Inspect code, review structure, and stay in control without the weight of a full IDE." />
    <meta property="og:title" content="Jelly — Lightweight desktop editor for agentic AI coding" />
    <meta property="og:description" content="Jelly is a lightweight desktop code editor built for developers who code with AI agents. Inspect code, review structure, and stay in control without the weight of a full IDE." />
    {import.meta.env.PROD && (
      <script defer src="https://analytics.mxv.sh/script.js" data-website-id="4ced3bae-4180-4105-8ca6-ab8c5022d894"></script>
    )}
  </head>
  <body class="bg-background text-ink selection:bg-jelly-cream/80">
    <div class="min-h-screen bg-background text-ink">
      <Nav />
      <main>
        <Hero />
        <Marquee />
        <Pillars />
        <FeatureSplit />
        <CommandSection />
        <SpecGrid />
        <Quote />
        <CTA />
      </main>
      <Footer />
    </div>
  </body>
</html>
