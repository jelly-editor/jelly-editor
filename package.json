{
  "name": "jelly-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/extensions/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "tauri:dev": "turbo run tauri:dev",
    "build": "turbo run build",
    "tauri:build": "turbo run tauri:build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  }
}
